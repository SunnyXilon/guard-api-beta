RTCM_ENVIRONMENT=production
RTCM_APP_NAME=Guard API
RTCM_EXPOSE_API_DOCS=false
RTCM_SESSION_SECRET=replace-with-a-strong-random-secret
RTCM_DATABASE_URL=postgresql+psycopg://guard_api:replace-with-postgres-password@postgres:5432/guard_api
RTCM_INFERENCE_SERVICE_URL=https://inference.your-domain.example
RTCM_CORS_ALLOWED_ORIGINS=["https://app.your-domain.example"]
RTCM_OPENAI_API_KEY=sk-proj-replace-with-openai-key
RTCM_AUDIO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
RTCM_AUDIO_TRANSCRIPTION_REQUIRED=true
RTCM_AUDIO_UPLOAD_MAX_BYTES=25000000
RTCM_BOOTSTRAP_API_KEYS=false
RTCM_BOOTSTRAP_DEFAULT_KEYS=
RTCM_BOOTSTRAP_ADMIN_KEYS=
RTCM_SELF_SERVICE_ONBOARDING_ENABLED=true
RTCM_CLERK_JWKS_URL=https://your-clerk-frontend-api/.well-known/jwks.json
RTCM_CLERK_JWT_KEY=
RTCM_CLERK_ISSUER=https://your-clerk-issuer
RTCM_CLERK_AUTHORIZED_PARTIES=["https://app.your-domain.example"]
RTCM_BOOTSTRAP_MONTHLY_QUOTA=1000
RTCM_REQUEST_RATE_LIMIT_PER_MINUTE=120
RTCM_RATE_LIMIT_REDIS_URL=redis://redis:6379/0
RTCM_IMAGE_UPLOAD_MAX_BYTES=6000000
RTCM_IMAGE_SCANNING_REQUIRED=true
RTCM_GOOGLE_VISION_MAX_LABELS=10
RTCM_LOCAL_VISION_SAFETY_ENABLED=true
RTCM_LOCAL_VISION_MODEL_NAME=ViT-B-32
RTCM_LOCAL_VISION_PRETRAINED=openai
RTCM_LOCAL_VISION_DEVICE=cpu
RTCM_LOCAL_VISION_THRESHOLD=0.23
RTCM_LOCAL_VISION_TOP_K=5
RTCM_VIDEO_UPLOAD_MAX_BYTES=60000000
RTCM_VIDEO_FRAME_SAMPLE_SECONDS=2.0
RTCM_VIDEO_MAX_FRAMES=12
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-vision-service-account.json
RTCM_META_GRAPH_API_BASE_URL=https://graph.facebook.com/v19.0
RTCM_META_OAUTH_DIALOG_BASE_URL=https://www.facebook.com/v19.0/dialog/oauth
RTCM_META_APP_ID=replace-with-meta-app-id
RTCM_META_APP_SECRET=replace-with-meta-app-secret
RTCM_META_OAUTH_REDIRECT_URI=https://api.your-domain.example/connectors/meta/oauth/callback
RTCM_META_OAUTH_SCOPES=["public_profile","pages_show_list","pages_read_engagement","pages_manage_metadata","instagram_basic","instagram_manage_comments"]
RTCM_META_ACTION_TIMEOUT_SECONDS=10.0
RTCM_CONNECTOR_WEBHOOK_SIGNING_SECRET=replace-with-random-webhook-signing-secret

RTCM_BILLING_REQUIRED=true
RTCM_STRIPE_SECRET_KEY=sk_live_replace_me
RTCM_STRIPE_WEBHOOK_SECRET=whsec_replace_me
RTCM_BILLING_SUCCESS_URL=https://app.your-domain.example?billing=success
RTCM_BILLING_CANCEL_URL=https://app.your-domain.example?billing=cancelled
RTCM_BILLING_PORTAL_RETURN_URL=https://app.your-domain.example/dashboard
RTCM_BILLING_PLAN_PRICE_IDS={"starter":"price_replace_starter","growth":"price_replace_growth","scale":"price_replace_scale"}
RTCM_BILLING_PLAN_QUOTAS={"starter":1000,"growth":100000,"scale":500000}
